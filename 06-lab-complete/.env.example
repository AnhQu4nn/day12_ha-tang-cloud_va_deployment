# Copy to .env.local for Docker Compose, or set the same variables in Railway.
# Do not commit local secret files.

# Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=false

# App
APP_NAME=Day09 Multi-Agent Shopping Assistant
APP_VERSION=1.0.0

# LLM label shown in API responses. The demo mode does not require a provider key.
LLM_MODEL=day09-demo
OPENAI_API_KEY=

# Required for protected endpoints: POST /ask and GET /metrics
AGENT_API_KEY=replace-with-a-long-random-key
JWT_SECRET=replace-with-a-long-random-secret

# Rate & budget guards
RATE_LIMIT_PER_MINUTE=20
DAILY_BUDGET_USD=5.0

# CORS
ALLOWED_ORIGINS=*
